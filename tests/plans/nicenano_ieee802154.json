    "post_load_settle_s": 5.0
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "generic",
    "duration_s": 20,
    "expect_patterns": [
      "AEL_IEEE802154_PASS"
    ]
  },
  "bench_setup": {
    "notes": "Stage 2 (no extra wiring). Tests IEEE 802.15.4 radio on nRF52840 (same 2.4 GHz radio as BLE). TX frame on ch15, verify TX completes. Self-RX attempted as bonus.",
    "peripheral_signals": []
  },
  "preflight": {
    "enabled": false
  }
