  "covers": [
    "ieee802154",
    "nrf5_radio",
    "2.4ghz",
    "thread_radio"
  ],
  "build": {
    "type": "zephyr",
    "zephyr_board": "nrf52840dk/nrf52840",
    "project_dir": "firmware/targets/nrf52840_nicenano_ieee802154",
    "artifact_stem": "zephyr",
    "build_dir": "artifacts/build_nicenano_ieee802154",
    "extra_overlay_file": "firmware/targets/nrf52840_nicenano_ieee802154/app.overlay"
  },
  "flash": {
    "method": "uf2_copy",
    "uf2_mount_path": "/media/aes/NICENANO",
