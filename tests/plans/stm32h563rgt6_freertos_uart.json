{
  "schema_version": "1.0",
  "test_kind": "observe_uart",
  "name": "stm32h563rgt6_freertos_uart",
  "board": "stm32h563rgt6",
  "supported_instruments": ["daplink"],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": ["uart_observed", "freertos", "rtos"],
  "covers": ["usart1", "uart_tx", "freertos_scheduler", "multitask"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32h563rgt6_freertos_uart",
    "artifact_stem": "stm32h563rgt6_freertos_uart",
    "build_dir": "artifacts/build_stm32h563rgt6_freertos_uart"
  },
  "signal_checks": [],
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "stm32",
    "duration_s": 8,
    "expect_patterns": [
      "STM32H563_FREERTOS_A TICK",
      "STM32H563_FREERTOS_B TICK"
    ]
  },
  "bench_setup": {
    "serial_console": {
      "port": "/dev/ttyACM0",
      "baud": 115200,
      "required": true
    },
    "notes": "FreeRTOS two-task UART pilot on STM32H563RGT6 (Cortex-M33). ARM_CM33_NTZ port. task_a 500ms, task_b 700ms. DAPLink UART bridge PA9 → /dev/ttyACM0.",
    "peripheral_signals": [
      {
        "role": "uart_tx",
        "dut_signal": "PA9/USART1_TX",
        "direction": "output",
        "notes": "AF7, connect to DAPLink RX"
      }
    ]
  }
}
