{
  "schema_version": "1.0",
  "test_kind": "zephyr_uart_observe",
  "name": "stm32h563rgt6_zephyr_philosophers",
  "board": "stm32h563rgt6",
  "supported_instruments": ["daplink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_swd"],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": ["zephyr", "uart_observe", "rtos", "regression"],
  "covers": ["zephyr_scheduler", "mutex", "multi_thread", "preemption", "verify"],
  "preflight": {
    "enabled": false
  },
  "notes": "Runs Zephyr upstream samples/philosophers on nucleo_h563zi (DTS overlay → USART1 PA9). Six threads compete for mutexes (forks) demonstrating preemptible+cooperative scheduling, mutex contention, and thread sleeping. AEL verifies EATING and THINKING states appear, proving scheduler and mutex subsystem are operational. Console on PA9 (USART1) 115200 8N1 via DAPLink /dev/ttyACM0.",
  "build": {
    "type": "zephyr",
    "zephyr_board": "nucleo_h563zi",
    "project_dir": "/home/aes/zephyrproject/zephyr/samples/philosophers",
    "build_dir": "artifacts/build_stm32h563rgt6_zephyr_philosophers",
    "extra_overlay_file": "firmware/targets/stm32h563rgt6_zephyr_philosophers/boards/nucleo_h563zi.overlay"
  },
  "flash": {
    "method": "zephyr_west",
    "runner": "pyocd",
    "build_dir": "artifacts/build_stm32h563rgt6_zephyr_philosophers",
    "post_load_settle_s": 1.5
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "stm32",
    "duration_s": 12,
    "expect_patterns": [
      "Philosopher",
      "EATING",
      "THINKING"
    ]
  },
  "bench_setup": {
    "instrument_roles": [
      {
        "role": "control_instrument",
        "instrument_id": "daplink_h563rgt6_local",
        "required": true,
        "notes": "Onboard CMSIS-DAP (DAPLink) for SWD flash via west flash --runner pyocd."
      }
    ],
    "serial_console": {
      "port": "/dev/ttyACM0",
      "baud": 115200,
      "required": true,
      "notes": "DAPLink USB CDC: STM32 PA9 (USART1_TX, AF7) bridged to /dev/ttyACM0."
    },
    "peripheral_signals": [
      {
        "role": "uart_tx",
        "dut_signal": "PA9/USART1_TX",
        "direction": "output",
        "notes": "Zephyr console UART. Connect to DAPLink UART RX."
      }
    ],
    "bench_connections": [
      {
        "from": "STM32 PA9 (USART1_TX)",
        "to": "DAPLink UART RX → /dev/ttyACM0"
      }
    ],
    "ground_required": true,
    "ground_confirmed": false
  }
}
