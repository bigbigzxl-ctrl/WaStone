{
  "schema_version": "1.0",
  "test_kind": "observe_uart",
  "name": "nicenano_i2c_loopback",
  "board": "nrf52840_nicenano",
  "supported_instruments": [],
  "labels": ["stage2", "i2c", "loopback", "uf2"],
  "covers": ["twim0", "twis1", "i2c_master", "i2c_slave"],
  "build": {
    "type": "zephyr",
    "zephyr_board": "nrf52840dk/nrf52840",
    "project_dir": "firmware/targets/nrf52840_nicenano_i2c_loopback",
    "artifact_stem": "zephyr",
    "build_dir": "artifacts/build_nicenano_i2c_loopback",
    "extra_overlay_file": "firmware/targets/nrf52840_nicenano_i2c_loopback/app.overlay"
  },
  "flash": {
    "method": "uf2_copy",
    "uf2_mount_path": "/media/aes/NICENANO",
    "timeout_s": 30,
    "post_load_settle_s": 4.0
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "generic",
    "duration_s": 15,
    "expect_patterns": [
      "AEL_I2C_LOOPBACK_PASS"
    ]
  },
  "bench_setup": {
    "notes": "Stage 2. P0.28 (SCL) + P0.29 (SDA) shared between TWIM0 (master) and TWIS1 (slave @0x42). Add 4.7 kΩ pull-ups on SCL and SDA. No cross-wiring needed.",
    "peripheral_signals": [
      {
        "role": "I2C_SCL",
        "dut_signal": "P0.28",
        "direction": "bidirectional",
        "notes": "Add 4.7 kΩ pull-up to VCC"
      },
      {
        "role": "I2C_SDA",
        "dut_signal": "P0.29",
        "direction": "bidirectional",
        "notes": "Add 4.7 kΩ pull-up to VCC"
      }
    ]
  }
}
