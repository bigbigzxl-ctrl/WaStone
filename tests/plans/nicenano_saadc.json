{
  "schema_version": "1.0",
  "test_kind": "observe_uart",
  "name": "nicenano_saadc",
  "board": "nrf52840_nicenano",
  "supported_instruments": [],
  "labels": ["stage2", "adc", "saadc", "no_wire", "uf2"],
  "covers": ["saadc", "ain7", "vbatt_divider"],
  "build": {
    "type": "zephyr",
    "zephyr_board": "nrf52840dk/nrf52840",
    "project_dir": "firmware/targets/nrf52840_nicenano_saadc",
    "artifact_stem": "zephyr",
    "build_dir": "artifacts/build_nicenano_saadc",
    "extra_overlay_file": "firmware/targets/nrf52840_nicenano_saadc/app.overlay"
  },
  "flash": {
    "method": "uf2_copy",
    "uf2_mount_path": "/media/aes/NICENANO",
    "timeout_s": 30,
    "post_load_settle_s": 4.0
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "generic",
    "duration_s": 15,
    "expect_patterns": [
      "AEL_SAADC_PASS"
    ]
  },
  "bench_setup": {
    "notes": "Stage 2 (no extra wiring). P0.31 = AIN7 on-board VBATT divider. ADC reads non-zero, non-railed value (100–4000 raw). USB power → ~1.65 V expected.",
    "peripheral_signals": [
      {
        "role": "VBATT_ADC",
        "dut_signal": "P0.31",
        "direction": "input",
        "notes": "On-board VBATT voltage divider — no extra wire needed"
      }
    ]
  }
}
