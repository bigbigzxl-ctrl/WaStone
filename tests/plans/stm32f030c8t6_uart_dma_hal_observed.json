{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f030c8t6_uart_dma_hal_observed",
  "board": "stm32f030c8t6_daplink_uart",
  "supported_instruments": ["daplink"],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": ["diagnostic", "uart_observed", "uart_dma", "deferred_debug", "hal_reference"],
  "covers": ["usart1", "dma1", "uart_dma", "uart_tx"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_uart_dma_hal_observed",
    "artifact_stem": "stm32f030c8t6_uart_dma_hal_observed_app",
    "build_dir": "artifacts/build_stm32f030c8t6_uart_dma_hal_observed"
  },
  "signal_checks": [],
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 9600,
    "profile": "stm32",
    "duration_s": 6,
    "expect_patterns": [
      "AEL_HAL_UART_DMA_BEGIN",
      "AEL_HAL_UART_DMA_TX",
      "AEL_HAL_UART_DMA_OK"
    ]
  },
  "bench_setup": {
    "serial_console": {
      "port": "/dev/ttyACM0",
      "baud": 9600,
      "required": true
    },
    "notes": "Deferred debug-only ST HAL reference proof for STM32F030C8T6 USART1 TX DMA on the DAPLink UART fixture. This is not part of the canonical suite; it exists to prove that the hardware path works under a minimal official HAL-style implementation.",
    "peripheral_signals": [
      {
        "role": "UART_TX_DMA",
        "dut_signal": "PA9/USART1_TX",
        "direction": "output",
        "notes": "Connect STM32 PA9 to DAPLink RX."
      },
      {
        "role": "UART_RX_PRESENT",
        "dut_signal": "PA10/USART1_RX",
        "direction": "input",
        "notes": "Connect DAPLink TX to STM32 PA10. Present but unused by this TX-only HAL proof."
      }
    ]
  }
}
