{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f030c8t6_minimal_runtime_mailbox",
  "board": "stm32f030c8t6_daplink",
  "supported_instruments": ["daplink"],
  "requires": { "mailbox": true, "datacapture": false },
  "labels": ["mailbox", "minimal_runtime", "stage0"],
  "covers": ["runtime_gate", "mailbox", "board_health"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_minimal_runtime_mailbox",
    "artifact_stem": "stm32f030c8t6_minimal_runtime_mailbox_app",
    "build_dir": "artifacts/build_stm32f030c8t6_minimal_runtime_mailbox"
  },
  "signal_checks": [],
  "mailbox_verify": { "settle_s": 4.0, "addr": "0x20001C00" },
