{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f030c8t6_spi1_loopback_mailbox",
  "board": "stm32f030c8t6_daplink",
  "supported_instruments": ["daplink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "cross_instrument"],
  "covers": ["spi1", "spi"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_spi1_loopback_mailbox",
    "artifact_stem": "stm32f030c8t6_spi1_loopback_mailbox_app",
    "build_dir": "artifacts/build_stm32f030c8t6_spi1_loopback_mailbox"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 30.0,
    "addr": "0x20001C00"
  },
  "bench_setup": {
    "notes": "SPI1 loopback: PA7 MOSI -> PA6 MISO with PA5 as SCK. PASS after exact echo of the pattern set.",
    "peripheral_signals": [
      {
        "role": "SPI1_MOSI",
        "dut_signal": "PA7",
        "direction": "output",
        "notes": "Wire PA7 -> PA6."
      },
      {
        "role": "SPI1_MISO",
        "dut_signal": "PA6",
        "direction": "input",
        "notes": "Wire PA7 -> PA6."
      },
      {
        "role": "SPI1_SCK",
        "dut_signal": "PA5",
        "direction": "output",
        "notes": "No extra wire required."
      }
    ]
  }
}
