{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f103rct6_uart_dma",
  "board": "stm32f103rct6",
  "supported_instruments": ["stlink", "esp32jtag"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "uart_observed"],
  "covers": ["usart1", "dma1", "uart_dma", "uart_tx"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f103rct6_uart_dma",
    "artifact_stem": "stm32f103rct6_uart_dma_app",
    "build_dir": "artifacts/build_stm32f103rct6_uart_dma"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 5.0,
    "addr": "0x2000BC00"
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "stm32",
    "duration_s": 6,
    "expect_patterns": [
      "AEL_UART_DMA A1 B2 C3 D4 55 66 77 88"
    ]
  },
  "bench_setup": {
    "serial_console": {
      "port": "/dev/ttyACM0",
      "baud": 115200,
      "required": true
    },
    "notes": "USART1 DMA TX proof on the current DAPLink UART fixture. DMA1 Channel4 feeds USART1_DR with a fixed frame over PA9 at 115200 8N1 and reports PASS through mailbox after the first complete DMA transfer. Host UART should observe 'AEL_UART_DMA A1 B2 C3 D4 55 66 77 88'.",
    "peripheral_signals": [
      {
        "role": "UART_TX_DMA",
        "dut_signal": "PA9/USART1_TX",
        "direction": "output",
        "notes": "Connect STM32 PA9 to DAPLink RX."
      },
      {
        "role": "UART_RX_DMA",
        "dut_signal": "PA10/USART1_RX",
        "direction": "input",
        "notes": "Connect DAPLink TX to STM32 PA10. Present on the fixture but unused by this TX proof."
      }
    ]
  }
}
