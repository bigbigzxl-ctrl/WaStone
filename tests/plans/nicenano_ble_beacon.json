{
  "schema_version": "1.0",
  "test_kind": "observe_uart",
  "name": "nicenano_ble_beacon",
  "board": "nrf52840_nicenano",
  "supported_instruments": [],
  "labels": [
    "stage2",
    "ble",
    "radio",
    "no_wire",
    "uf2"
  ],
  "covers": [
    "ble",
    "bt_broadcaster",
    "2.4ghz_radio"
  ],
  "build": {
    "type": "zephyr",
    "zephyr_board": "nrf52840dk/nrf52840",
    "project_dir": "firmware/targets/nrf52840_nicenano_ble_beacon",
    "artifact_stem": "zephyr",
    "build_dir": "artifacts/build_nicenano_ble_beacon",
    "extra_overlay_file": "firmware/targets/nrf52840_nicenano_ble_beacon/app.overlay"
  },
  "flash": {
    "method": "uf2_copy",
    "uf2_mount_path": "/media/aes/NICENANO",
    "timeout_s": 30,
    "post_load_settle_s": 5.0
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "generic",
    "duration_s": 20,
    "expect_patterns": [
      "AEL_BLE_BEACON_PASS"
    ]
  },
  "bench_setup": {
    "notes": "Stage 2 (no extra wiring). Tests BLE 2.4 GHz radio stack. Advertises AEL beacon, counts TX events. No second device required.",
    "peripheral_signals": []
  },
  "preflight": {
    "enabled": false
  }
}
