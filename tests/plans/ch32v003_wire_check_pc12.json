{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "ch32v003_wire_check_pc12",
  "board": "ch32v003xxx",
  "supported_instruments": ["wchlink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_sdi"],
  "requires": { "mailbox": true, "datacapture": false },
  "labels": ["mailbox", "ch32v003", "gpio", "wire_check", "prestage"],
  "covers": ["ch32v003_wire_pc1_pc2"],
  "preflight": { "enabled": false },
  "notes": "Prestage connectivity check: PC2 drives HIGH/LOW, PC1 reads back. Verifies PC1↔PC2 wire required by i2c_loopback and exti_loopback tests. PASS = both transitions match.",
  "build": {
    "type": "arm_debug",
    "project_dir": "firmware/targets/ch32v003_wire_check_pc12",
    "artifact_stem": "ch32v003_wire_check_pc12"
  },
  "flash": { "method": "wch_openocd", "post_load_settle_s": 1.0 },
  "mailbox_verify": {
    "settle_s": 1.0,
    "addr": "0x20000600",
    "skip_attach": true,
    "halt_before_read": true,
    "check_mode": "pass_fail",
    "detach_resume_target": "wch_riscv.cpu.0",
    "post_resume_openocd_bin": "/nvme1t/wch-riscv-gcc/openocd/bin/openocd",
    "post_resume_openocd_cfg": "/nvme1t/wch-riscv-gcc/openocd/bin/wch-riscv.cfg"
  },
  "observe_uart": { "enabled": false },
  "bench_setup": {
    "bench_connections": [
      { "from": "CH32V003 PC2 (I2C SCL)", "to": "CH32V003 PC1 (I2C SDA) — loopback wire" },
      { "from": "WCHLink SWDIO",          "to": "CH32V003 PD1 (SDI)" },
      { "from": "WCHLink GND",            "to": "CH32V003 GND" }
    ],
    "ground_required": true,
    "ground_confirmed": false
  }
}
