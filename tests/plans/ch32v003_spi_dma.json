{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "ch32v003_spi_dma",
  "board": "ch32v003xxx",
  "supported_instruments": ["wchlink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_sdi"],
  "requires": { "mailbox": true, "datacapture": false },
  "labels": ["mailbox", "ch32v003", "spi", "dma", "loopback"],
  "covers": ["ch32v003_spi1_dma_tx_rx"],
  "preflight": { "enabled": false },
  "notes": "SPI1 DMA loopback: DMA1_Ch3 TX + DMA1_Ch2 RX. 8 bytes via MOSI→MISO wire. PASS if all 8 RX bytes match TX. Wire: PC6(MOSI)↔PC7(MISO).",
  "build": {
    "type": "arm_debug",
    "project_dir": "firmware/targets/ch32v003_spi_dma",
    "artifact_stem": "ch32v003_spi_dma"
  },
  "flash": { "method": "wch_openocd", "post_load_settle_s": 1.5 },
  "mailbox_verify": {
    "settle_s": 2.0,
    "addr": "0x20000600",
    "skip_attach": true,
    "halt_before_read": true,
    "check_mode": "pass_fail",
    "detach_resume_target": "wch_riscv.cpu.0",
    "post_resume_openocd_bin": "/nvme1t/wch-riscv-gcc/openocd/bin/openocd",
    "post_resume_openocd_cfg": "/nvme1t/wch-riscv-gcc/openocd/bin/wch-riscv.cfg"
  },
  "observe_uart": { "enabled": false },
  "bench_setup": {
    "bench_connections": [
      { "from": "WCHLink SWDIO",    "to": "CH32V003 PD1 (SDI)" },
      { "from": "WCHLink GND",      "to": "CH32V003 GND" },
      { "from": "CH32V003 PC6 (MOSI)", "to": "CH32V003 PC7 (MISO)" }
    ],
    "ground_required": true,
    "ground_confirmed": false
  }
}
