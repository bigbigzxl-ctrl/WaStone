  "supported_instruments": [
    "daplink"
  ],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": [
    "mailbox"
  ],
  "covers": [
    "dac",
    "adc",
    "loopback"
  ],
  "preflight": {
    "enabled": false
  },
  "build": {
    "project_dir": "firmware/targets/stm32h563rgt6_dac_adc",
    "artifact_stem": "stm32h563rgt6_dac_adc_app",
    "build_dir": "artifacts/build_stm32h563rgt6_dac_adc"
