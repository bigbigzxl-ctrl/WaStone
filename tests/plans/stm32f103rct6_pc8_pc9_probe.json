{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f103rct6_pc8_pc9_probe",
  "board": "stm32f103rct6",
  "supported_instruments": ["stlink", "esp32jtag", "daplink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "diagnostic", "gpio"],
  "covers": ["gpio", "wiring"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f103rct6_pc8_pc9_probe",
    "artifact_stem": "stm32f103rct6_pc8_pc9_probe_app",
    "build_dir": "artifacts/build_stm32f103rct6_pc8_pc9_probe"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 4.0,
    "addr": "0x2000BC00"
  },
  "bench_setup": {
    "notes": "Diagnostic GPIO probe on GPIOC upper pins. PC8 drives repeated toggles while PC9 is wired to PC8 and read as an input pull-down observer. PASS after repeated high and low reads are both confirmed.",
    "peripheral_signals": [
      {
        "role": "GPIO_PROBE_DRIVER",
        "dut_signal": "PC8",
        "direction": "output",
        "notes": "Wire PC8 -> PC9."
      },
      {
        "role": "GPIO_PROBE_INPUT",
        "dut_signal": "PC9",
        "direction": "input",
        "notes": "Wire PC8 -> PC9."
      }
    ]
  }
}
