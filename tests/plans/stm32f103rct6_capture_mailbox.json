{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f103rct6_capture_mailbox",
  "board": "stm32f103rct6",
  "supported_instruments": ["stlink", "esp32jtag"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "cross_instrument"],
  "covers": ["capture", "timer"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f103rct6_capture_mailbox",
    "artifact_stem": "stm32f103rct6_capture_mailbox_app",
    "build_dir": "artifacts/build_stm32f103rct6_capture_mailbox"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 5.0,
    "addr": "0x2000BC00"
  },
  "bench_setup": {
    "notes": "Capture mailbox test on the repaired PB8 -> PB9 wire. Firmware drives a software square wave on PB8, samples PB9, and uses TIM2 running at 1 MHz to measure the period between rising edges. PASS when the measured period stays in the expected window.",
    "peripheral_signals": [
      {
        "role": "CAPTURE_SOURCE",
        "dut_signal": "PB8",
        "direction": "output",
        "notes": "GPIO output push-pull. Wire: PB8 -> PB9."
      },
      {
        "role": "CAPTURE_INPUT",
        "dut_signal": "PB9",
        "direction": "input",
        "notes": "GPIO input pull-down. Wire: PB8 -> PB9."
      }
    ]
  }
}
