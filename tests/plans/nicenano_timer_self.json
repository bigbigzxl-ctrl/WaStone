{
  "schema_version": "1.0",
  "test_kind": "observe_uart",
  "name": "nicenano_timer_self",
  "board": "nrf52840_nicenano",
  "supported_instruments": [],
  "labels": [
    "stage1",
    "no_wire",
    "timer",
    "uf2"
  ],
  "covers": [
    "timer0",
    "interrupt",
    "nvic"
  ],
  "build": {
    "type": "zephyr",
    "zephyr_board": "nrf52840dk/nrf52840",
    "project_dir": "firmware/targets/nrf52840_nicenano_stage1",
    "artifact_stem": "zephyr",
    "build_dir": "artifacts/build_nicenano_stage1",
    "extra_overlay_file": "firmware/targets/nrf52840_nicenano_stage1/app.overlay"
  },
  "flash": {
    "method": "uf2_copy",
    "uf2_mount_path": "/media/aes/NICENANO",
    "timeout_s": 30,
    "post_load_settle_s": 4.0
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "generic",
    "duration_s": 25,
    "expect_patterns": [
      "\\[TIMER\\].*PASS"
    ]
  },
  "bench_setup": {
    "notes": "Stage 1 no-wire. TIMER0 32-bit free-run at 16 MHz, 1 s reference via Zephyr uptime. Accepts ±5% error.",
    "peripheral_signals": []
  },
  "preflight": {
    "enabled": false
  }
}
