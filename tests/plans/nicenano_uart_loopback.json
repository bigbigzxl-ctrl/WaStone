{
  "schema_version": "1.0",
  "test_kind": "observe_uart",
  "name": "nicenano_uart_loopback",
  "board": "nrf52840_nicenano",
  "supported_instruments": [],
  "labels": ["stage2", "uart", "loopback", "uf2"],
  "covers": ["uarte1", "dma", "uart_tx", "uart_rx"],
  "build": {
    "type": "zephyr",
    "zephyr_board": "nrf52840dk/nrf52840",
    "project_dir": "firmware/targets/nrf52840_nicenano_uart_loopback",
    "artifact_stem": "zephyr",
    "build_dir": "artifacts/build_nicenano_uart_loopback",
    "extra_overlay_file": "firmware/targets/nrf52840_nicenano_uart_loopback/app.overlay"
  },
  "flash": {
    "method": "uf2_copy",
    "uf2_mount_path": "/media/aes/NICENANO",
    "timeout_s": 30,
    "post_load_settle_s": 4.0
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "generic",
    "duration_s": 15,
    "expect_patterns": [
      "AEL_UART_LOOPBACK_PASS"
    ]
  },
  "bench_setup": {
    "notes": "Stage 2. Wire P0.20 (UART1 TX) → P0.17 (UART1 RX). Sends 32 bytes, verifies round-trip.",
    "peripheral_signals": [
      {
        "role": "UART1_TX",
        "dut_signal": "P0.20",
        "direction": "output",
        "notes": "Wire to P0.17 (RX)"
      },
      {
        "role": "UART1_RX",
        "dut_signal": "P0.17",
        "direction": "input",
        "notes": "Wire from P0.20 (TX)"
      }
    ]
  }
}
