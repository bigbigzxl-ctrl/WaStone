{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f103rct6_pb8_pb9_probe",
  "supported_instruments": ["stlink", "esp32jtag"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "diagnostic"],
  "covers": ["gpio", "wiring"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f103rct6_pb8_pb9_probe",
    "artifact_stem": "stm32f103rct6_pb8_pb9_probe_app",
    "build_dir": "artifacts/build_stm32f103rct6_pb8_pb9_probe"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 60.0,
    "addr": "0x2000BC00"
  },
  "bench_setup": {
    "notes": "Diagnostic GPIO probe. PB8 drives repeated high/low states; PB9 is polled directly as a plain input. detail0 packs successful reads as (high_ok << 16) | low_ok. Wire: PB8 -> PB9.",
    "peripheral_signals": [
      {
        "role": "GPIO_PROBE_DRIVER",
        "dut_signal": "PB8",
        "direction": "output",
        "notes": "GPIO output push-pull. Wire: PB8 -> PB9."
      },
      {
        "role": "GPIO_PROBE_INPUT",
        "dut_signal": "PB9",
        "direction": "input",
        "notes": "GPIO input floating. Wire: PB8 -> PB9."
      }
    ]
  }
}
