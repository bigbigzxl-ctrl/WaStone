{
  "name": "stm32f103_capture_banner",
  "board": "stm32f103_gpio",
  "pin": "sig",
  "duration_s": 1.0,
  "min_freq_hz": 35.0,
  "max_freq_hz": 70.0,
  "duty_min": 0.4,
  "duty_max": 0.6,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32f103_capture",
    "artifact_stem": "stm32f103_capture_app",
    "build_dir": "artifacts/build_stm32f103_capture_banner"
  },
  "bench_setup": {
    "peripheral_signals": [
      {
        "role": "TIM1_CH1_SOURCE",
        "dut_signal": "PA8",
        "direction": "output",
        "notes": "Firmware drives a 50 Hz source on PA8 for the timing/capture self-check."
      },
      {
        "role": "TIM4_CH3_CAPTURE_INPUT",
        "dut_signal": "PB8",
        "direction": "input",
        "notes": "Firmware captures rising edges on PB8 through a manual PA8 -> PB8 loopback and exports success on PA4."
      }
    ],
    "external_inputs": [
      {
        "source": "CAPTURE_LOOPBACK",
        "dut_signal": "PB8",
        "kind": "digital_loopback",
        "required": true,
        "status": "provisioned",
        "notes": "Execution contract: physically connect PA8 to PB8 so the DUT can validate timing capture internally. AEL should observe PA4, not PA8/PB8, for the bounded proof."
      }
    ]
  }
}
