    "peripheral_signals": [
      {
        "role": "GPIO_PROBE_INPUT",
        "dut_signal": "PA6",
        "direction": "input",
        "notes": "Wire PA7 -> PA6."
      },
      {
        "role": "GPIO_PROBE_DRIVER",
        "dut_signal": "PA7",
        "direction": "output",
        "notes": "Wire PA7 -> PA6."
      }
    ]
  }
