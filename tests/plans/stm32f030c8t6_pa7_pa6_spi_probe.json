{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f030c8t6_pa7_pa6_spi_probe",
  "board": "stm32f030c8t6_daplink",
  "supported_instruments": ["daplink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "diagnostic", "connectivity"],
  "covers": ["gpio", "wiring", "pre_stage2_connectivity"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_pa7_pa6_spi_probe",
    "artifact_stem": "stm32f030c8t6_pa7_pa6_spi_probe_app",
    "build_dir": "artifacts/build_stm32f030c8t6_pa7_pa6_spi_probe"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 3.0,
    "addr": "0x20001C00"
  },
  "bench_setup": {
