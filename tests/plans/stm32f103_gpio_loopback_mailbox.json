{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f103_gpio_loopback_mailbox",
  "board": "stm32f103_gpio",
  "supported_instruments": ["esp32jtag", "stlink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "cross_instrument"],
  "covers": ["gpio"],
  "preflight": {
    "enabled": false
  },
  "build": {
    "project_dir": "firmware/targets/stm32f103_gpio_loopback_mailbox",
    "artifact_stem": "stm32f103_gpio_loopback_mailbox_app",
    "build_dir": "artifacts/build_stm32f103_gpio_loopback_mailbox"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "addr": "0x20004C00",
    "settle_s": 1.0
  },
  "bench_setup": {
    "notes": "GPIO loopback mailbox test. Requires PA8 -> PB8. DUT drives repeated high/low states on PA8, samples PB8, and reports PASS/FAIL through the AEL mailbox.",
    "peripheral_signals": [
      {
        "role": "GPIO_LOOPBACK_SOURCE",
        "dut_signal": "PA8",
        "direction": "output"
      },
      {
        "role": "GPIO_LOOPBACK_INPUT",
        "dut_signal": "PB8",
        "direction": "input"
      }
    ]
  }
}
