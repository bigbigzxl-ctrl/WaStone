{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "ch32v203_usart_halfduplex",
  "board": "ch32v203xxx",
  "supported_instruments": ["wchlink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_sdi"],
  "requires": { "mailbox": true, "datacapture": false },
  "labels": ["mailbox", "ch32v203", "usart", "halfduplex", "stage3"],
  "covers": ["ch32v203_usart_half_duplex"],
  "preflight": { "enabled": false },
  "build": {
    "type": "arm_debug",
    "project_dir": "firmware/targets/ch32v203_usart_halfduplex",
    "artifact_stem": "ch32v203_usart_halfduplex"
  },
  "flash": { "method": "wch_openocd", "post_load_settle_s": 1.5 },
  "mailbox_verify": {
    "settle_s": 1.5,
    "addr": "0x20000600",
    "skip_attach": true,
    "halt_before_read": true,
    "check_mode": "detail0_increment",
    "increment_wait_s": 3,
    "detach_resume_target": "wch_riscv.cpu.0",
    "post_resume_openocd_bin": "/nvme1t/wch-riscv-gcc/openocd/bin/openocd",
    "post_resume_openocd_cfg": "/nvme1t/wch-riscv-gcc/openocd/bin/wch-riscv.cfg"
  },
  "bench_setup": {
    "notes": "USART2 half-duplex self-loopback on PA2 (AF_OD). PA3 configured as GPIO IPU provides pull-up via Stage-1 PA2↔PA3 jumper. No extra wires needed beyond Stage-1.",
    "bench_connections": [
      { "from": "WCHLink SWDIO",  "to": "CH32V203 PA13" },
      { "from": "WCHLink SWDCLK", "to": "CH32V203 PA14" },
      { "from": "WCHLink GND",    "to": "CH32V203 GND"  },
      { "from": "WCHLink 3V3",    "to": "CH32V203 3V3"  },
      { "from": "CH32V203 PA2",   "to": "CH32V203 PA3 (Stage-1 jumper, already in place)" }
    ],
    "ground_required": true
  }
}
