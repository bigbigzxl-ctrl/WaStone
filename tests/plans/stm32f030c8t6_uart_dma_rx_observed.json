{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f030c8t6_uart_dma_rx_observed",
  "board": "stm32f030c8t6_daplink_uart",
  "supported_instruments": ["daplink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "uart_observed", "uart_dma_debug"],
  "covers": ["usart1", "dma1", "uart_dma", "uart_rx"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_uart_dma_rx_observed",
    "artifact_stem": "stm32f030c8t6_uart_dma_rx_observed_app",
    "build_dir": "artifacts/build_stm32f030c8t6_uart_dma_rx_observed"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 5.0,
    "addr": "0x20001C00"
  },
  "host_uart_exchange": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "ready_patterns": ["AEL_UART_DMA_RX_READY"],
    "tx": "PING_DMA_RX",
    "append_newline": false,
    "expect_patterns": ["AEL_UART_DMA_RX_OK"],
    "startup_wait_s": 3.0,
    "ready_timeout_s": 6.0,
    "response_timeout_s": 4.0
  },
  "bench_setup": {
    "serial_console": {
      "port": "/dev/ttyACM0",
      "baud": 115200,
      "required": true
    },
    "notes": "Debug-only USART1 DMA RX proof on the DAPLink UART fixture for STM32F030C8T6. Host sends PING_DMA_RX on DAPLink TX->PA10. Firmware arms DMA1 Channel3 for USART1_RDR and reports status over ordinary UART TX.",
    "peripheral_signals": [
      {
        "role": "UART_TX_DEBUG",
        "dut_signal": "PA9/USART1_TX",
        "direction": "output",
        "notes": "Connect STM32 PA9 to DAPLink RX for diagnostic text."
      },
      {
        "role": "UART_RX_DMA",
        "dut_signal": "PA10/USART1_RX",
        "direction": "input",
        "notes": "Connect DAPLink TX to STM32 PA10 for host-driven DMA RX."
      }
    ]
  }
}
