{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "ch32v003_gpio_loopback",
  "board": "ch32v003xxx",
  "supported_instruments": ["wchlink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_sdi"],
  "requires": { "mailbox": true, "datacapture": false },
  "labels": ["mailbox", "ch32v003", "gpio", "loopback"],
  "covers": ["ch32v003_gpio_pc6_pc7", "loopback_connectivity"],
  "preflight": { "enabled": false },
  "notes": "PC6 drives HIGH/LOW, PC7 reads back. PASS = both match. After test PC6 blinks for LED verification.",
  "build": {
    "type": "arm_debug",
    "project_dir": "firmware/targets/ch32v003_gpio_loopback",
    "artifact_stem": "ch32v003_gpio_loopback"
  },
  "flash": { "method": "wch_openocd", "post_load_settle_s": 1.0 },
  "mailbox_verify": {
    "settle_s": 1.0,
    "addr": "0x20000600",
    "skip_attach": true,
    "halt_before_read": true,
    "check_mode": "detail0_increment",
    "increment_wait_s": 3,
    "post_resume_openocd_bin": "/nvme1t/wch-riscv-gcc/openocd/bin/openocd",
    "post_resume_openocd_cfg": "/nvme1t/wch-riscv-gcc/openocd/bin/wch-riscv.cfg"
  },
  "bench_setup": {
    "bench_connections": [
      { "from": "CH32V003 PC6", "to": "CH32V003 PC7 (loopback wire)" },
      { "from": "LED anode",    "to": "CH32V003 PC6 (via 330 Ω)" },
      { "from": "WCHLink SWDIO","to": "CH32V003 PD1 (SDI)" },
      { "from": "WCHLink GND",  "to": "CH32V003 GND" }
    ],
    "ground_required": true,
    "ground_confirmed": false
  }
}
