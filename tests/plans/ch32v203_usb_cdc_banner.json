{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "ch32v203_usb_cdc_banner",
  "board": "ch32v203xxx",
  "supported_instruments": ["wchlink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_sdi"],
  "requires": { "mailbox": true, "datacapture": false },
  "labels": ["mailbox", "ch32v203", "usb", "cdc", "stage3"],
  "covers": ["ch32v203_usb_cdc_enumeration"],
  "preflight": { "enabled": false },
  "build": {
    "type": "arm_debug",
    "project_dir": "firmware/targets/ch32v203_usb_cdc_banner",
    "artifact_stem": "ch32v203_usb_cdc_banner"
  },
  "flash": { "method": "wch_openocd", "post_load_settle_s": 2.0 },
  "mailbox_verify": {
    "settle_s": 90.0,
    "addr": "0x20000600",
    "halt_before_read": true,
    "check_mode": "detail0_increment",
    "increment_wait_s": 4,
    "detach_resume_target": "wch_riscv.cpu.0",
    "post_resume_openocd_bin": "/nvme1t/wch-riscv-gcc/openocd/bin/openocd",
    "post_resume_openocd_cfg": "/nvme1t/wch-riscv-gcc/openocd/bin/wch-riscv.cfg"
  },
  "bench_setup": {
    "notes": "MANUAL STEP: after flash completes (~25s into run), unplug then replug the USB-C cable (PA11/PA12). Board power-cycles, firmware restarts, USB enumerates in <2s. Test waits 90s total. detail0=0xCDC on PASS.",
    "bench_connections": [
      { "from": "WCHLink SWDIO",       "to": "CH32V203 PA13" },
      { "from": "WCHLink SWDCLK",      "to": "CH32V203 PA14" },
      { "from": "WCHLink GND",         "to": "CH32V203 GND"  },
      { "from": "WCHLink 3V3",         "to": "CH32V203 3V3"  },
      { "from": "Host USB-C port",     "to": "CH32V203 USB port (PA11/PA12)" }
    ],
    "ground_required": true
  }
}
