{
  "schema_version": "1.0",
  "test_kind": "zephyr_uart_observe",
  "name": "stm32f103rct6_zephyr_philosophers",
  "board": "stm32f103rct6",
  "supported_instruments": ["daplink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_swd"],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": ["zephyr", "uart_observe", "rtos", "regression"],
  "covers": ["zephyr_scheduler", "mutex", "multi_thread", "preemption", "verify"],
  "preflight": {
    "enabled": false
  },
  "notes": "Runs Zephyr upstream samples/philosophers on stm32f103_mini (STM32F103RCT6). Six threads compete for mutexes demonstrating preemptible+cooperative scheduling. AEL verifies EATING and THINKING states. Raw UART contains VT100 cursor codes (\\x1b[N;1H) — substring match unaffected. Console on PA9 (USART1 TX) via DAPLink built-in UART bridge at /dev/ttyACM0.",
  "build": {
    "type": "zephyr",
    "zephyr_board": "stm32f103_mini",
    "project_dir": "/home/aes/zephyrproject/zephyr/samples/philosophers",
    "build_dir": "artifacts/build_stm32f103rct6_zephyr_philosophers"
  },
  "flash": {
    "method": "zephyr_west",
    "runner": "openocd",
    "build_dir": "artifacts/build_stm32f103rct6_zephyr_philosophers",
    "post_load_settle_s": 1.5
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "stm32",
    "duration_s": 12,
    "expect_patterns": [
      "Philosopher",
      "EATING",
      "THINKING"
    ]
  },
  "bench_setup": {
    "instrument_roles": [
      {
        "role": "control_instrument",
        "instrument_id": "daplink_f103_rct6",
        "required": true,
        "notes": "DAPLink CMSIS-DAP via USB. SWD flash + built-in UART bridge for console capture."
      }
    ],
    "serial_console": {
      "port": "/dev/ttyACM0",
      "baud": 115200,
      "required": true,
      "notes": "DAPLink built-in USB UART bridge. PA9 (USART1_TX) -> DAPLink RX. No separate USB-UART adapter needed."
    },
    "peripheral_signals": [
      {
        "role": "uart_tx",
        "dut_signal": "PA9/USART1_TX",
        "direction": "output",
        "notes": "Zephyr console UART on stm32f103_mini DTS. Connected to DAPLink RX (existing golden suite wiring)."
      }
    ],
    "bench_connections": [
      {
        "from": "STM32F103RCT6 PA9 (USART1_TX)",
        "to": "DAPLink RX"
      },
      {
        "from": "DAPLink GND",
        "to": "STM32F103RCT6 GND"
      }
    ],
    "ground_required": true,
    "ground_confirmed": true
  }
}
