  },
  "labels": ["mailbox", "portable", "cross_instrument"],
  "covers": ["timer", "pwm"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_tim3_pwm_pb0_pb1_mailbox",
    "artifact_stem": "stm32f030c8t6_tim3_pwm_pb0_pb1_mailbox_app",
