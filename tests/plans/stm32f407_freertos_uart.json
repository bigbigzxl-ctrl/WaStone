{
  "schema_version": "1.0",
  "test_kind": "observe_uart",
  "name": "stm32f407_freertos_uart",
  "board": "stm32f407_discovery",
  "supported_instruments": ["stlink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_swd"],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": ["uart_observed", "freertos", "rtos"],
  "covers": ["usart2", "uart_tx", "freertos_scheduler", "multitask"],
  "preflight": { "enabled": false },
  "build": {
    "type": "arm_debug",
    "project_dir": "firmware/targets/stm32f407_freertos_uart",
    "artifact_stem": "stm32f407_freertos_uart",
    "build_dir": "artifacts/build_stm32f407_freertos_uart"
  },
  "flash": {
    "method": "gdbmi",
    "gdb_launch_cmds": [
      "file {firmware}",
      "load",
      "monitor reset run",
      "disconnect"
    ],
    "post_load_settle_s": 1.5
  },
  "signal_checks": [],
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "baud": 115200,
    "profile": "stm32",
    "duration_s": 8,
    "expect_patterns": [
      "STM32F407_FREERTOS_A TICK",
      "STM32F407_FREERTOS_B TICK"
    ]
  },
  "bench_setup": {
    "serial_console": {
      "port": "/dev/ttyUSB0",
      "baud": 115200,
      "required": true,
      "notes": "CH341 USB-serial: STM32 PA2 (USART2_TX, AF7) → CH341 RXD → /dev/ttyUSB0"
    },
    "peripheral_signals": [
      {
        "role": "uart_tx",
        "dut_signal": "PA2/USART2_TX",
        "direction": "output",
        "notes": "AF7, 115200 8N1. Connect to CH341 USB-serial RXD."
      }
    ],
    "bench_connections": [
      {
        "from": "STM32 PA2 (USART2_TX)",
        "to": "CH341 USB-serial RXD"
      },
      {
        "from": "STM32 GND",
        "to": "CH341 GND"
      }
    ],
    "notes": "FreeRTOS two-task UART pilot on STM32F407VGT6 (F4 Discovery, Cortex-M4). ARM_CM3 port (no FPU). task_a 500ms, task_b 700ms. CH341 UART bridge PA2 → /dev/ttyUSB0. USART2 16MHz HSI, BRR=0x8B (115200 baud)."
  }
}
