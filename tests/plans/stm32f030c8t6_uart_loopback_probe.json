{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f030c8t6_uart_loopback_probe",
  "board": "stm32f030c8t6_daplink",
  "supported_instruments": ["daplink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "diagnostic", "connectivity"],
  "covers": ["uart", "wiring", "pre_stage2_connectivity"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_uart_loopback_probe",
    "artifact_stem": "stm32f030c8t6_uart_loopback_probe_app",
    "build_dir": "artifacts/build_stm32f030c8t6_uart_loopback_probe"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 2.0,
    "addr": "0x20001C00"
  },
  "bench_setup": {
    "notes": "Pre-Stage2 UART local loopback probe on STM32F030C8T6. Requires PA9/USART1_TX -> PA10/USART1_RX. DUT performs a bounded self-check and reports PASS/FAIL only through the mailbox.",
    "peripheral_signals": [
      {
        "role": "USART1_TX",
        "dut_signal": "PA9",
        "direction": "output",
        "notes": "Wire PA9 -> PA10."
      },
      {
        "role": "USART1_RX",
        "dut_signal": "PA10",
        "direction": "input",
        "notes": "Wire PA9 -> PA10."
      }
    ]
  }
}
