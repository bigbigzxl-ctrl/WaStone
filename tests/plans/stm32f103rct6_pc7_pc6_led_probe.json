{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f103rct6_pc7_pc6_led_probe",
  "board": "stm32f103rct6",
  "supported_instruments": ["stlink", "esp32jtag", "daplink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "stage0", "board_health"],
  "covers": ["gpio", "board_health", "led_probe"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f103rct6_pc7_pc6_led_probe",
    "artifact_stem": "stm32f103rct6_pc7_pc6_led_probe_app",
    "build_dir": "artifacts/build_stm32f103rct6_pc7_pc6_led_probe"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 4.0,
    "addr": "0x2000BC00"
  },
  "bench_setup": {
    "notes": "Stage 0 LED probe. PC7 continues driving the onboard LED line while PC6 is wired to PC7 as an input pull-down observer. PASS after the firmware confirms repeated high and low reads on PC6.",
    "peripheral_signals": [
      {
        "role": "LED_DRIVE",
        "dut_signal": "PC7",
        "direction": "output",
        "notes": "PC7 LED drive output. Wire PC7 -> PC6."
      },
      {
        "role": "LED_SENSE",
        "dut_signal": "PC6",
        "direction": "input",
        "notes": "PC6 input pull-down observer. Wire PC7 -> PC6."
      }
    ]
  }
}
