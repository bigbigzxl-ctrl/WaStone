{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "ch32v003_uart_bidir",
  "board": "ch32v003xxx",
  "supported_instruments": ["wchlink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_sdi"],
  "requires": { "mailbox": true, "datacapture": false },
  "labels": ["mailbox", "ch32v003", "uart", "bidir", "wchlink"],
  "covers": ["ch32v003_usart1_pd5_tx", "ch32v003_usart1_pd6_rx", "wchlink_cdc_uart_bidir"],
  "preflight": { "enabled": false },
  "notes": "USART1 TX=PD5→WCH-Link RX, RX=PD6←WCH-Link TX @ 115200 (APB2=8MHz, BRR=0x0045). TX verified by observe_uart. RX verified by detail0_increment: GDB injects 5 bytes via /dev/ttyACM0 after T1 read; firmware counts received bytes in detail0.",
  "build": {
    "type": "arm_debug",
    "project_dir": "firmware/targets/ch32v003_uart_bidir",
    "artifact_stem": "ch32v003_uart_bidir"
  },
  "flash": { "method": "wch_openocd", "post_load_settle_s": 1.5 },
  "mailbox_verify": {
    "settle_s": 1.5,
    "addr": "0x20000600",
    "skip_attach": true,
    "halt_before_read": true,
    "check_mode": "detail0_increment",
    "increment_wait_s": 3,
    "shell_cmd_after_t1_resume": "python3 -c \"import serial,time; s=serial.Serial('/dev/ttyACM0',115200,timeout=1); time.sleep(0.3); [s.write(b'X') for _ in range(5)]; s.close()\"",
    "detach_resume_target": "wch_riscv.cpu.0",
    "post_resume_openocd_bin": "/nvme1t/wch-riscv-gcc/openocd/bin/openocd",
    "post_resume_openocd_cfg": "/nvme1t/wch-riscv-gcc/openocd/bin/wch-riscv.cfg"
  },
  "observe_uart": { "enabled": false },
  "bench_setup": {
    "bench_connections": [
      { "from": "WCHLink SWDIO", "to": "CH32V003 PD1 (SDI)" },
      { "from": "WCHLink GND",   "to": "CH32V003 GND" },
      { "from": "WCHLink RX",    "to": "CH32V003 PD5 (USART1_TX)" },
      { "from": "WCHLink TX",    "to": "CH32V003 PD6 (USART1_RX)" }
    ],
    "ground_required": true,
    "ground_confirmed": false
  }
}
