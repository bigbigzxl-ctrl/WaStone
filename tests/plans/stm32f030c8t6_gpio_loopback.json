{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f030c8t6_gpio_loopback",
  "board": "stm32f030c8t6_daplink",
  "supported_instruments": ["daplink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "cross_instrument"],
  "covers": ["gpio"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_gpio_loopback",
    "artifact_stem": "stm32f030c8t6_gpio_loopback_app",
    "build_dir": "artifacts/build_stm32f030c8t6_gpio_loopback"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 30.0,
    "addr": "0x20001C00"
  },
  "bench_setup": {
    "notes": "GPIO loopback: PB0 drives high/low and PB1 reads back. PASS after 10 successful cycles.",
    "peripheral_signals": [
      {
        "role": "GPIO_OUT",
        "dut_signal": "PB0",
        "direction": "output",
        "notes": "Wire PB0 -> PB1."
      },
      {
        "role": "GPIO_IN",
        "dut_signal": "PB1",
        "direction": "input",
        "notes": "Wire PB0 -> PB1."
      }
    ]
  }
}
