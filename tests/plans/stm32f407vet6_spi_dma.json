{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f407vet6_spi_dma",
  "board": "stm32f407vet6",
  "supported_instruments": ["esp32jtag"],
  "requires": {"mailbox": true, "datacapture": false},
  "labels": ["mailbox"],
  "covers": ["spi", "dma"],
  "preflight": {"enabled": false},
  "build": {
    "project_dir": "firmware/targets/stm32f407vet6_spi_dma",
    "artifact_stem": "stm32f407vet6_spi_dma",
    "build_dir": "artifacts/build_stm32f407vet6_spi_dma"
  },
  "signal_checks": [],
  "mailbox_verify": {"settle_s": 5.0, "addr": "0x2001FC00", "skip_attach": false},
  "bench_setup": {
    "notes": "SPI2 DMA loopback on PB15(MOSI)↔PB14(MISO). TX via DMA1 Stream4 CH0, RX via DMA1 Stream3 CH0. Sends 8 bytes simultaneously, verifies match. PASS: detail0=8. Reuses existing SPI loopback wire.",
    "peripheral_signals": [
      {
        "role": "SPI_MOSI",
        "dut_signal": "PB15",
        "direction": "out",
        "notes": "SPI2_MOSI AF5, looped to PB14"
      },
      {
        "role": "SPI_MISO",
        "dut_signal": "PB14",
        "direction": "in",
        "notes": "SPI2_MISO AF5, looped from PB15"
      },
      {
        "role": "SPI_SCK",
        "dut_signal": "PB13",
        "direction": "out",
        "notes": "SPI2_SCK AF5, no loopback needed"
      }
    ]
  }
}
