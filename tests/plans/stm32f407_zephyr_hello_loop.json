{
  "schema_version": "1.0",
  "test_kind": "zephyr_uart_observe",
  "name": "stm32f407_zephyr_hello_loop",
  "board": "stm32f407_discovery",
  "supported_instruments": ["stlink"],
  "applies_to": ["board"],
  "requires_dut_features": ["programmable_via_swd"],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": ["zephyr", "uart_observe", "regression"],
  "covers": ["zephyr_backend", "observe_uart", "verify"],
  "preflight": {
    "enabled": false
  },
  "notes": "Builds and flashes a minimal Zephyr app that prints AEL_ZEPHYR_IDLE every 500ms on USART2/PA2 (115200 8N1). AEL observe_uart captures the pattern without race conditions. Validated on STM32F4 Discovery (STM32F407VGT6) with Zephyr 4.4.0-rc2.",
  "build": {
    "type": "zephyr",
    "zephyr_board": "stm32f4_disco",
    "project_dir": "firmware/targets/stm32f407_zephyr_hello_loop",
    "build_dir": "artifacts/build_stm32f407_zephyr_hello_loop"
  },
  "flash": {
    "method": "zephyr_west",
    "runner": "openocd",
    "build_dir": "artifacts/build_stm32f407_zephyr_hello_loop",
    "post_load_settle_s": 1.5
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "baud": 115200,
    "profile": "stm32",
    "duration_s": 6,
    "expect_patterns": [
      "AEL_ZEPHYR_IDLE"
    ]
  },
  "bench_setup": {
    "instrument_roles": [
      {
        "role": "control_instrument",
        "instrument_id": "stlink_f407_discovery",
        "required": true,
        "notes": "Onboard ST-Link/V2-A used for SWD flash via west flash --runner openocd."
      }
    ],
    "serial_console": {
      "port": "/dev/ttyUSB0",
      "baud": 115200,
      "required": true,
      "notes": "USB-UART adapter: STM32 PA2 (USART2_TX) -> RXD, GND -> GND."
    },
    "peripheral_signals": [
      {
        "role": "uart_tx",
        "dut_signal": "PA2/USART2_TX",
        "direction": "output",
        "notes": "Zephyr console UART. Connect to USB-UART adapter RXD."
      }
    ],
    "bench_connections": [
      {
        "from": "STM32 PA2 (USART2_TX)",
        "to": "USB-UART adapter RXD"
      },
      {
        "from": "STM32 GND",
        "to": "USB-UART adapter GND"
      }
    ],
    "ground_required": true,
    "ground_confirmed": false
  }
}
