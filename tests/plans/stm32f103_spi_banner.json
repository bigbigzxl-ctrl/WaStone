{
  "name": "stm32f103_spi_banner",
  "board": "stm32f103_gpio",
  "pin": "sig",
  "duration_s": 1.0,
  "min_freq_hz": 35.0,
  "max_freq_hz": 70.0,
  "duty_min": 0.4,
  "duty_max": 0.6,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32f103_spi",
    "artifact_stem": "stm32f103_spi_app",
    "build_dir": "artifacts/build_stm32f103_spi_banner"
  },
  "bench_setup": {
    "peripheral_signals": [
      {
        "role": "SPI1_SCK",
        "dut_signal": "PA5",
        "direction": "output"
      },
      {
        "role": "SPI1_MISO",
        "dut_signal": "PA6",
        "direction": "input"
      },
      {
        "role": "SPI1_MOSI",
        "dut_signal": "PA7",
        "direction": "output"
      }
    ],
    "external_inputs": [
      {
        "source": "SPI_LOOPBACK",
        "dut_signal": "PA6/SPI1_MISO",
        "kind": "digital_loopback",
        "required": true,
        "status": "provisioned",
        "notes": "Execution contract: physically connect PA7/SPI1_MOSI to PA6/SPI1_MISO. Firmware performs a bounded SPI loopback self-check internally and exports SPI-valid status on PA4."
      }
    ]
  }
}
