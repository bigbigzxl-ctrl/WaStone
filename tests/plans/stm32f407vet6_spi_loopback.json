        "role": "SPI_MOSI",
        "dut_signal": "PA7",
        "direction": "output",
        "notes": "SPI1 MOSI, AF5. Wire: PA7 \u2192 PA6."
      },
      {
        "role": "SPI_MISO",
        "dut_signal": "PA6",
        "direction": "input",
        "notes": "SPI1 MISO, AF5. Wire: PA7 \u2192 PA6."
      }
    ]
  }
