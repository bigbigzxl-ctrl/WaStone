{
  "name": "stm32f103_adc_banner",
  "board": "stm32f103_gpio",
  "pin": "sig",
  "duration_s": 1.0,
  "min_freq_hz": 35.0,
  "max_freq_hz": 70.0,
  "duty_min": 0.4,
  "duty_max": 0.6,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32f103_adc",
    "artifact_stem": "stm32f103_adc_app",
    "build_dir": "artifacts/build_stm32f103_adc_banner"
  },
  "bench_setup": {
    "peripheral_signals": [
      {
        "role": "ADC1_IN0",
        "dut_signal": "PA0/ADC1_IN0",
        "direction": "input"
      },
      {
        "role": "ADC_LOOPBACK_SOURCE",
        "dut_signal": "PA1",
        "direction": "output",
        "notes": "Firmware drives PA1 at about 100 Hz and samples PA0/ADC1_IN0 through a physical loopback jumper."
      }
    ],
    "external_inputs": [
      {
        "source": "PA1_LOOPBACK",
        "dut_signal": "PA0/ADC1_IN0",
        "kind": "analog_in",
        "required": true,
        "status": "provisioned",
        "notes": "Execution contract: physically connect PA1 to PA0 so the DUT can self-drive a 100 Hz square wave into ADC1_IN0 during runtime validation."
      }
    ]
  }
}
