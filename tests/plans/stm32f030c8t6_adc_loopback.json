{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f030c8t6_adc_loopback",
  "board": "stm32f030c8t6_daplink",
  "supported_instruments": ["daplink"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "cross_instrument"],
  "covers": ["adc"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f030c8t6_adc_loopback",
    "artifact_stem": "stm32f030c8t6_adc_loopback_app",
    "build_dir": "artifacts/build_stm32f030c8t6_adc_loopback"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 30.0,
    "addr": "0x20001C00"
  },
  "bench_setup": {
    "notes": "ADC loopback: PA0 drives high/low and PA1 ADC reads back. PASS after 5 good high/low samples.",
    "peripheral_signals": [
      {
        "role": "ADC_DRIVER",
        "dut_signal": "PA0",
        "direction": "output",
        "notes": "Wire PA0 -> PA1."
      },
      {
        "role": "ADC_IN",
        "dut_signal": "PA1",
        "direction": "input",
        "notes": "Wire PA0 -> PA1."
      }
    ]
  }
