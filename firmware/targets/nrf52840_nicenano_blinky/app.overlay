/*
 * nice!nano blinky overlay — nrf52840dk/nrf52840 base
 *
 * - Redirects code partition to 0x1000 (Adafruit UF2 bootloader layout)
 * - Adds nice!nano LED alias on P0.15 (active-high blue LED)
 * - Adds USB CDC so 1200-baud bootloader re-entry works
 */

/ {
    chosen {
        zephyr,console = &cdc_acm_uart0;
        zephyr,shell-uart = &cdc_acm_uart0;
        zephyr,code-partition = &nicenano_app;
    };

    aliases {
        led0 = &nicenano_led;
    };

    leds {
        compatible = "gpio-leds";
        nicenano_led: nicenano_led_0 {
            /* P0.15 — blue LED, active HIGH on nice!nano v1 */
            gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
            label = "nice!nano Blue LED";
        };
    };
};

&flash0 {
    partitions {
        nicenano_app: partition@1000 {
            label = "nicenano-app";
            reg = <0x00001000 0x000EE000>;
        };
    };
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};
